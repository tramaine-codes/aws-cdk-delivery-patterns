{
  "bin": {
    "aws-cdk-delivery-patterns": "bin/aws-cdk-delivery-patterns.js"
  },
  "dependencies": {
    "aws-cdk-lib": "2.244.0",
    "constructs": "10.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@types/node": "24.12.0",
    "@vitest/coverage-v8": "4.1.1",
    "aws-cdk": "2.1113.0",
    "cdk-nag": "2.37.55",
    "del-cli": "7.0.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.1"
  },
  "engines": {
    "node": "24.14.0",
    "npm": "11.12.0"
  },
  "homepage": "https://github.com/tramaine-codes/aws-cdk-delivery-patterns",
  "name": "aws-cdk-delivery-patterns",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/tramaine-codes/aws-cdk-delivery-patterns.git"
  },
  "scripts": {
    "build": "tsc",
    "build:ci": "npm run clean && npm test && tsc",
    "cdk": "cdk",
    "clean": "del-cli coverage",
    "format": "biome format --fix --no-errors-on-unmatched .",
    "lint": "biome lint --no-errors-on-unmatched .",
    "lint:fix": "biome lint --fix --no-errors-on-unmatched .",
    "prepare": "husky",
    "test": "vitest run --dir test/unit --config ./vite.config.unit.ts",
    "test:cov": "vitest run --coverage --dir test/unit --config ./vite.config.unit.ts",
    "test:watch": "vitest --dir test/unit --config ./vite.config.unit.ts",
    "watch": "tsc -w"
  },
  "type": "module",
  "version": "0.1.0",
  "volta": {
    "node": "24.14.0",
    "npm": "11.12.0"
  }
}
